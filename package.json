{
  "name": "mnuda",
  "version": "1.0.0",
  "private": true,
  "description": "Minnesota Realtors Platform - A platform for Minnesota Realtors to drop a pin to start a lead or listing",
  "keywords": ["real estate", "minnesota", "realtors", "map", "leads", "listings"],
  "author": "MNUDA Team",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "analyze": "ANALYZE=true npm run build",
    "preview": "next build && next start",
    "clean": "rm -rf .next out",
    "postbuild": "next-sitemap"
  },
  "dependencies": {
    "next": "14.0.4",
    "react": "^18",
    "react-dom": "^18",
    "@supabase/supabase-js": "^2.38.4",
    "mapbox-gl": "^2.15.0",
    "react-map-gl": "^7.1.7",
    "next-sitemap": "^4.2.3"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "eslint": "^8",
    "eslint-config-next": "14.0.4",
    "webpack-bundle-analyzer": "^4.10.1",
    "@types/mapbox-gl": "^2.7.18"
  }
}
